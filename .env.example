# === vLLM API ===
VLLM_BASE_URL=https://your-vllm-server.example.com/v1
VLLM_MODEL_NAME=your-model-name
VLLM_API_KEY=your_vllm_api_key_here

# === Hsueh vLLM API (備用) ===
HSUEH_VLLM_BASE_URL=https://your-backup-vllm.example.com/v1
HSUEH_VLLM_MODEL_NAME=your-backup-model-name
HSUEH_VLLM_API_KEY=dummy

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === Pipeline 設定 ===
RELEVANCE_SCORE_THRESHOLD=5
MAX_ARTICLES_PER_RUN=50
USE_HSUEH_VLLM=false

# === Discovery 設定 ===
TAVILY_API_KEY=your_tavily_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
# 若以約 4 credits / topic 估算，8 個 topics / day 約 960 credits / 30 天
# 建議配置為 4 個純科技 + 4 個教育科技
DISCOVERY_TOPICS=generative AI,vibe coding,AI agents,cybersecurity and consumer electronics,AI tutoring,teacher copilots,learning analytics,edtech policy and academic integrity
DISCOVERY_QUERY_TEMPLATE={topic} education technology news {coverage_date}
DISCOVERY_MAX_SOURCES_PER_TOPIC=5
DISCOVERY_MAX_AGE_DAYS=30
DISCOVERY_ALLOW_UNDATED_SOURCES=false
