# === vLLM API ===
VLLM_BASE_URL=https://your-vllm-server.example.com/v1
VLLM_MODEL_NAME=your-model-name
VLLM_API_KEY=your_vllm_api_key_here

# === Hsueh vLLM API (備用) ===
HSUEH_VLLM_BASE_URL=https://your-backup-vllm.example.com/v1
HSUEH_VLLM_MODEL_NAME=your-backup-model-name
HSUEH_VLLM_API_KEY=dummy

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === Pipeline 設定 ===
RELEVANCE_SCORE_THRESHOLD=5
MAX_ARTICLES_PER_RUN=50
USE_HSUEH_VLLM=false
